    fig.add_annotation(x=1.5, y=1.5, text="Under Budget<br>Ahead Schedule", showarrow=False,
                       font={"size": 10, "color": "#00d4aa"})
    fig.add_annotation(x=0.5, y=0.5, text="Over Budget<br>Behind Schedule", showarrow=False,
                       font={"size": 10, "color": "#ef4444"})
    fig.add_annotation(x=1.5, y=0.5, text="Over Budget<br>Ahead Schedule", showarrow=False,
                       font={"size": 10, "color": "#f59e0b"})
    fig.update_layout(
        title={"text": title, "font": {"size": 14, "color": "#e2e8f0"}},
        paper_bgcolor="rgba(0,0,0,0)", plot_bgcolor="rgba(0,0,0,0)",
        height=280, margin=dict(l=10, r=10, t=40, b=10))
    return fig

def create_ev_bar_chart(df, title):
    """Create EV bar chart (BAC/PV/EV/AC)."""
    fig = go.Figure()
    metrics = ["BAC", "PV", "EV", "AC"]
    colors = ["#6b7280", "#00a8e8", "#00d4aa", "#ef4444"]
    for metric, color in zip(metrics, colors):
        if metric in df.columns:
            fig.add_trace(go.Bar(x=df["Project"], y=df[metric], name=metric, marker_color=color))
    fig.update_layout(
        barmode="group",
        title={"text": title, "font": {"size": 14, "color": "#e2e8f0"}},
        paper_bgcolor="rgba(0,0,0,0)", plot_bgcolor="rgba(0,0,0,0)",
        height=280, margin=dict(l=10, r=10, t=40, b=10),
        legend=dict(orientation="h", yanchor="bottom", y=-0.2, font={"size": 10}))
    return fig

def create_evm_trend(df, title):
    """Create EVM trend line chart."""
    fig = go.Figure()
    if "SPI" in df.columns:
        fig.add_trace(go.Scatter(x=df["Date"], y=df["SPI"], name="SPI",
                                 line=dict(color="#00d4aa", width=2)))
    if "CPI" in df.columns:
        fig.add_trace(go.Scatter(x=df["Date"], y=df["CPI"], name="CPI",
                                 line=dict(color="#00a8e8", width=2)))
    fig.add_hline(y=1.0, line_dash="dash", line_color="rgba(255,255,255,0.3)")
    fig.update_layout(
        title={"text": title, "font": {"size": 14, "color": "#e2e8f0"}},
        paper_bgcolor="rgba(0,0,0,0)", plot_bgcolor="rgba(0,0,0,0)",
        height=280, margin=dict(l=10, r=10, t=40, b=10),
        legend=dict(orientation="h", yanchor="bottom", y=-0.2, font={"size": 10}))
    return fig

