def render_claims():
    """Render claims intelligence page."""
    st.markdown('<div class="main-header">🎯 Claims Intelligence</div>', unsafe_allow_html=True)

    project_id = st.session_state.selected_project_id
    ctx = get_project_context(project_id)
    data = get_project_data(project_id)

    claims_intel = ClaimsIntelligence(ctx)

    st.markdown("#### 📝 Issue Evaluation")

    with st.expander("➕ Add New Issue", expanded=True):
        col1, col2 = st.columns(2)
        with col1:
            issue_title = st.text_input("Issue Title", placeholder="e.g., Steel Supply Delay Claim")
        with col2:
            issue_description = st.text_area("Issue Description", 
                                            placeholder="Describe the claim issue...",
                                            height=100)

        if st.button("🔍 Evaluate Issue", type="primary", use_container_width=True):
            if issue_title and issue_description:
                with st.spinner("Evaluating claim..."):
                    result = claims_intel.evaluate_issue(
                        issue_title,
                        issue_description,
                        claims_intel.load_contract_clauses(),
                        data.get("claim_evidence", pd.DataFrame()),
                        data.get("delay_events", pd.DataFrame()),
                        data.get("payments", pd.DataFrame()),
                        data.get("letters", pd.DataFrame())
                    )

                    if "claims_results" not in st.session_state:
                        st.session_state.claims_results = []
                    st.session_state.claims_results.append(result)
                    st.success("✅ Evaluation complete!")
            else:
                st.error("Please provide both title and description")

    # Display results
    if "claims_results" in st.session_state and st.session_state.claims_results:
        st.markdown("---")
        st.markdown("#### 📋 Evaluation Results")

        for i, result in enumerate(st.session_state.claims_results):
            with st.expander(f"🎯 {result['issue_title']}", expanded=i == 0):
                # Decision badge
                decision_colors = {
                    "YES_VALID": "#00d4aa",
                    "YES_SUPPORTING": "#00a8e8",
                    "NO": "#ef4444",
                    "NOT_ENOUGH_DATA": "#f59e0b",
                    "COMMERCIAL_ONLY": "#8b5cf6"
                }
                color = decision_colors.get(result["decision"], "#6b7280")
                st.markdown(f"""
                <div style="background: {color}20; border-left: 4px solid {color}; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
                    <div style="font-size: 1.2rem; font-weight: 700; color: {color};">{result['claim_strength']}</div>
                    <div style="color: #8899a6; margin-top: 0.5rem;">Responsibility: <strong>{result['responsibility']}</strong></div>
                </div>
                """, unsafe_allow_html=True)

                cols = st.columns(3)
                with cols[0]:
                    render_metric_card("Time Impact", f"{result['time_impact_potential']:.0f} days")
                with cols[1]:
                    render_metric_card("Cost Impact", f"${result['cost_impact_potential']:,.0f}")
                with cols[2]:
                    render_metric_card("Evidence", len(result['evidence_used']))

                st.markdown("**Contract Basis:**")
                for clause in result["contract_basis"]:
                    st.markdown(f"- 📄 {clause['clause_id']}: {clause['clause_text'][:100]}...")

                if result["missing_evidence"]:
                    st.markdown("**⚠️ Missing Evidence:**")
                    for item in result["missing_evidence"]:
                        st.markdown(f"- ❌ {item}")

                st.markdown(f"**💡 Recommendation:** {result['recommended_next_action']}")

