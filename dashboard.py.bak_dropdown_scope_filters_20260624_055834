def create_radar_chart(categories, values, title, benchmark=None):
    """Create radar chart."""
    fig = go.Figure()
    fig.add_trace(go.Scatterpolar(
        r=values + [values[0]], theta=categories + [categories[0]],
        fill="toself", name="Current", line_color="#00d4aa",
        fillcolor="rgba(0,212,170,0.2)"))
    if benchmark:
        fig.add_trace(go.Scatterpolar(
            r=benchmark + [benchmark[0]], theta=categories + [categories[0]],
            fill="toself", name="Benchmark", line_color="#00a8e8",
            fillcolor="rgba(0,168,232,0.1)"))
    fig.update_layout(
        polar=dict(
            radialaxis=dict(visible=True, range=[0, 100], tickfont={"size": 10}, gridcolor="#2d3748"),
            angularaxis=dict(tickfont={"size": 11}, gridcolor="#2d3748"), bgcolor="#111827"),
        title={"text": title, "font": {"size": 14, "color": "#e2e8f0"}},
        paper_bgcolor="rgba(0,0,0,0)", height=280,
        margin=dict(l=30, r=30, t=50, b=10), showlegend=True,
        legend=dict(orientation="h", yanchor="bottom", y=-0.2, font={"size": 10}))
    return fig

def create_gantt_timeline(df, start_col, end_col, y_col, color_col):
    """Create Gantt timeline."""
    fig = px.timeline(df, x_start=start_col, x_end=end_col, y=y_col,
                      color=color_col,
                      color_discrete_sequence=["#00d4aa", "#00a8e8", "#ef4444", "#f59e0b"],
                      template="plotly_dark")
    fig.update_layout(
        paper_bgcolor="rgba(0,0,0,0)", plot_bgcolor="rgba(0,0,0,0)",
        height=280, margin=dict(l=10, r=10, t=30, b=10), showlegend=True,
        legend=dict(orientation="h", yanchor="bottom", y=-0.2, font={"size": 10}))
    fig.update_yaxes(autorange="reversed")
    return fig

def create_heatmap(z, x_labels, y_labels, title):
    """Create heatmap."""
    colorscale = [[0, "#00d4aa"], [0.5, "#f59e0b"], [1, "#ef4444"]]
    fig = go.Figure(data=go.Heatmap(
        z=z, x=x_labels, y=y_labels, colorscale=colorscale,
        showscale=True, colorbar=dict(tickfont={"size": 10}, thickness=10)))
    fig.update_layout(
        title={"text": title, "font": {"size": 14, "color": "#e2e8f0"}},
        paper_bgcolor="rgba(0,0,0,0)", plot_bgcolor="rgba(0,0,0,0)",
        height=280, margin=dict(l=10, r=10, t=40, b=10),
        xaxis=dict(tickfont={"size": 10}), yaxis=dict(tickfont={"size": 10}))
    return fig

def create_quadrant_scatter(df, x_col, y_col, color_col, title):
    """Create SPI vs CPI quadrant scatter."""
    fig = px.scatter(df, x=x_col, y=y_col, color=color_col,
                     size="Contract Value" if "Contract Value" in df.columns else None,
                     hover_name="Project" if "Project" in df.columns else None,
                     template="plotly_dark",
                     color_discrete_sequence=["#00d4aa", "#00a8e8", "#ef4444", "#f59e0b"])
    fig.add_hline(y=1.0, line_dash="dash", line_color="rgba(255,255,255,0.3)")
    fig.add_vline(x=1.0, line_dash="dash", line_color="rgba(255,255,255,0.3)")
    fig.add_annotation(x=0.5, y=1.5, text="Under Budget<br>Behind Schedule", showarrow=False,
