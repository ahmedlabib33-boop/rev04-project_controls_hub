@st.cache_data(ttl=300)
def get_project_context(project_id):
    """Get project context with caching."""
    return ProjectContext(project_id)

def get_project_data(project_id):
    """Load all project data with caching."""
    cache_key = f"data_{project_id}"
    if cache_key not in st.session_state.data_cache:
        ctx = get_project_context(project_id)
        importer = DataImporter(ctx)
        data = importer.load_all_project_data()
        st.session_state.data_cache[cache_key] = data
    return st.session_state.data_cache[cache_key]

def get_analytics(project_id, data):
    """Get analytics for project."""
    ctx = get_project_context(project_id)
    db = ProjectDatabase(str(ctx.contracts_db_path))
    analytics = ProjectAnalytics(ctx, db)
    return analytics.get_dashboard_summary(data)

def render_metric_card(title, value, delta=None, delta_color="normal"):
    """Render a modern metric card with safe delta handling."""
    delta_html = ""

    if delta is not None:
        try:
            delta_num = float(delta)
        except (TypeError, ValueError):
            delta_num = None

        if delta_num is not None and not pd.isna(delta_num) and np.isfinite(delta_num):
            arrow = "▲" if delta_num >= 0 else "▼"

            if delta_color == "inverse":
                color = "#ef4444" if delta_num >= 0 else "#00d4aa"
            else:
                color = "#00d4aa" if delta_num >= 0 else "#ef4444"

            delta_html = f'<div style="color: {color}; font-size: 0.9rem; margin-top: 0.25rem;">{arrow} {abs(delta_num):.1f}%</div>'

    st.markdown(f"""
    <div class="metric-card">
        <div class="metric-label">{title}</div>
        <div class="metric-value">{value}</div>
        {delta_html}
    </div>
    """, unsafe_allow_html=True)

def create_gauge_chart(value, title, max_val=100, color="#00d4aa"):
    """Create a gauge chart."""
    fig = go.Figure(go.Indicator(
        mode="gauge+number",
        value=value,
        title={"text": title, "font": {"size": 12, "color": "#8899a6"}},
        number={"font": {"size": 20, "color": color}},
        gauge={
            "axis": {"range": [0, max_val], "tickcolor": "#2d3748"},
            "bar": {"color": color},
            "bgcolor": "#1a2332",
            "borderwidth": 2,
            "bordercolor": "#2d3748",
            "steps": [
                {"range": [0, max_val*0.3], "color": "#1a2332"},
                {"range": [max_val*0.3, max_val*0.7], "color": "#1a2332"},
                {"range": [max_val*0.7, max_val], "color": "#1a2332"}
            ],
            "threshold": {
                "line": {"color": "red", "width": 2},
                "thickness": 0.75,
                "value": max_val * 0.9
            }
        }
    ))
    fig.update_layout(
        height=160, margin=dict(l=10, r=10, t=30, b=10),
        paper_bgcolor="rgba(0,0,0,0)", font={"color": "#e2e8f0"}
    )
    return fig

def create_donut_chart(labels, values, title, colors=None):
    """Create a donut chart."""
    if colors is None:
        colors = px.colors.sequential.Teal
    fig = px.pie(names=labels, values=values, hole=0.55,
                 color_discrete_sequence=colors, template="plotly_dark")
    fig.update_layout(
        title={"text": title, "font": {"size": 14, "color": "#e2e8f0"}},
        paper_bgcolor="rgba(0,0,0,0)", height=280,
        margin=dict(l=10, r=10, t=40, b=10),
        showlegend=True,
        legend=dict(orientation="h", yanchor="bottom", y=-0.15, font={"size": 10})
    )
    fig.update_traces(textinfo="percent", textfont={"size": 11})
    return fig

